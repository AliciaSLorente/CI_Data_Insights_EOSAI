# Copy this file to .env and fill in your values
# .env is git-ignored — never commit API keys

ANTHROPIC_API_KEY=your_api_key_here

# Optional: set if your hackathon provided a proxy URL
# ANTHROPIC_BASE_URL=https://proxy-url-from-hackathon

# Optional: override default model (useful for hackathon proxy keys)
# ANTHROPIC_MODEL=claude-sonnet-4-5
